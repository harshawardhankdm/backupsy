# Example: run backupsy on a schedule via GitHub Actions.
#
# This file is named *.example so it doesn't run in the backupsy repo itself.
# To use it in YOUR project: copy it to .github/workflows/backup.yml, add
# your config.yaml to the repo (with real paths for the runner), and set
# the secrets referenced below in your repo's Settings -> Secrets and variables.

name: Scheduled Backup

on:
  schedule:
    - cron: "0 3 * * *"  # every day at 03:00 UTC
  workflow_dispatch: {}   # allows manually triggering a run from the Actions tab

jobs:
  backup:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install backupsy
        run: pip install backupsy

      - name: Run backup
        env:
          BACKUPSY_S3_ACCESS_KEY: ${{ secrets.BACKUPSY_S3_ACCESS_KEY }}
          BACKUPSY_S3_SECRET_KEY: ${{ secrets.BACKUPSY_S3_SECRET_KEY }}
          BACKUPSY_WEBHOOK_URL: ${{ secrets.BACKUPSY_WEBHOOK_URL }}
        run: backupsy run --config config.yaml
